{
  "name": "mobile-software-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node ./node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@prisma/client": "^5.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.2",
    "@types/node": "^22.10.1",
    "prisma": "^5.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
